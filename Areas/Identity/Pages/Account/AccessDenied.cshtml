@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="container my-5 text-center" style="max-width: 600px;">
    <div class="card border-0 shadow-lg rounded-4 p-5 border-top border-danger border-5">
        <div class="mb-4 text-danger">
            <i class="bi bi-shield-slash fs-1" style="font-size: 4rem !important;"></i>
        </div>
        <h1 class="display-5 fw-bold text-danger mb-3">@ViewData["Title"]</h1>
        <p class="text-muted fs-5 mb-4">You do not have permission to access this resource or view this page.</p>
        <hr class="my-4" />
        <p class="text-secondary small mb-5">Please contact your administrator if you believe this is an error, or log in with a different account that has appropriate credentials.</p>
        
        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">Go to Home</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Log In</a>
        </div>
    </div>
</div>
