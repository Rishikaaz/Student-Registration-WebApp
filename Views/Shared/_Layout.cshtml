@using Microsoft.AspNetCore.Identity
@using StudentRegistrationWebApp.Data
@using Microsoft.EntityFrameworkCore
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject StudentCourseDbContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Registration Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudentRegistrationWebApp.styles.css" asp-append-version="true" />
    <style>
        .navbar {
            background: rgba(255, 255, 255, 0.9) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
        .nav-link {
            font-weight: 500;
            transition: color 0.15s ease;
        }
        .nav-link:hover {
            color: var(--bs-primary) !important;
        }
        .bg-primary-soft {
            background-color: rgba(13, 110, 253, 0.08);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light navbar-toggleable-sm bg-white box-shadow mb-3 py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-primary fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill me-2"></i>Student Registration
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            if (User.IsInRole("Administrator"))
                            {
                                <li class="nav-item me-2">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-house-door me-1"></i>Home
                                    </a>
                                </li>
                                <li class="nav-item me-2">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Courses" asp-action="Index">
                                        <i class="bi bi-book me-1"></i>Courses
                                    </a>
                                </li>
                                <li class="nav-item me-2">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Students" asp-action="Index">
                                        <i class="bi bi-people me-1"></i>Students
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Student"))
                            {
                                <li class="nav-item me-2">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-house-door me-1"></i>Home
                                    </a>
                                </li>
                                <li class="nav-item me-2">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Courses" asp-action="Index">
                                        <i class="bi bi-book me-1"></i>Courses
                                    </a>
                                </li>
                                
                                var userId = UserManager.GetUserId(User);
                                var student = DbContext.Students.FirstOrDefault(s => s.UserId == userId);
                                if (student != null && student.CourseId == null)
                                {
                                    <li class="nav-item me-2">
                                        <a class="nav-link text-dark" asp-area="" asp-controller="Students" asp-action="RegisterCourse">
                                            <i class="bi bi-plus-circle me-1"></i>Register for Course
                                        </a>
                                    </li>
                                }

                                <li class="nav-item me-2">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Students" asp-action="Profile">
                                        <i class="bi bi-person-badge me-1"></i>My Profile
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i>Home
                                </a>
                            </li>
                            <li class="nav-item me-2">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Courses" asp-action="Index">
                                    <i class="bi bi-book me-1"></i>Courses
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3 mt-5">
        <div class="container text-center">
            &copy; 2026 - StudentRegistrationWebApp - Made by Rishika Patel
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
