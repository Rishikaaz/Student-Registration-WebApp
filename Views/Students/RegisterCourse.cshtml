@{
    ViewData["Title"] = "Register for Course";
}

<div class="container my-5" style="max-width: 600px;">
    <div class="card border-0 shadow-lg rounded-4 p-4">
        <h1 class="display-6 fw-bold text-primary mb-3">Register for Course</h1>
        <p class="text-muted border-bottom pb-3 mb-4">Choose a course to enroll in. Remember that you can register for **only one** course.</p>

        <form asp-action="RegisterCourse" method="post">
            <div class="mb-4">
                <label class="form-label fw-bold text-secondary">Select Course</label>
                <select name="courseId" class="form-select form-select-lg rounded-3" asp-items="ViewBag.CourseId" required>
                    <option value="" disabled selected>-- Select a Course --</option>
                </select>
            </div>

            <div class="alert alert-warning border-0 small rounded-3 mb-4" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i>Once you choose a course, you will not be able to change it or register for another course.
            </div>

            <div class="d-flex gap-3 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">Confirm Registration</button>
                <a asp-controller="Students" asp-action="Profile" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Cancel</a>
            </div>
        </form>
    </div>
</div>
