@model StudentRegistrationWebApp.Models.Student
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container my-5" style="max-width: 600px;">
    <div class="card border-0 shadow-lg rounded-4 p-4">
        <h1 class="display-6 fw-bold text-primary mb-3">Edit Profile</h1>
        <p class="text-muted border-bottom pb-3 mb-4">Modify your personal registration details.</p>

        <form asp-action="EditProfile" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="StudentId" />

            <div class="mb-4">
                <label asp-for="FullName" class="form-label fw-bold text-secondary"></label>
                <input asp-for="FullName" class="form-control form-control-lg rounded-3" placeholder="Enter full name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="City" class="form-label fw-bold text-secondary"></label>
                <input asp-for="City" class="form-control form-control-lg rounded-3" placeholder="Enter city" />
                <span asp-validation-for="City" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-3 mt-5 pt-3 border-top">
                <button type="submit" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">Save Changes</button>
                <a asp-action="Profile" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Cancel</a>
            </div>
        </form>
    </div>
</div>
