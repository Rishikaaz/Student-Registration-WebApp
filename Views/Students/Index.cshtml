@model IEnumerable<StudentRegistrationWebApp.Models.Student>
@{
    ViewData["Title"] = "Students Directory";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h1 class="display-5 fw-bold text-primary mb-1">Students Directory</h1>
            <p class="text-muted mb-0">Manage and view all registered students and their course registrations.</p>
        </div>
        <div class="badge bg-secondary px-3 py-2 rounded-pill fs-6">
            Total: @Model.Count() Students
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light py-3 border-bottom">
                    <tr>
                        <th class="ps-4 py-3 text-secondary uppercase font-monospace fw-bold fs-7">Student ID</th>
                        <th class="py-3 text-secondary uppercase font-monospace fw-bold fs-7">Full Name</th>
                        <th class="py-3 text-secondary uppercase font-monospace fw-bold fs-7">City</th>
                        <th class="py-3 text-secondary uppercase font-monospace fw-bold fs-7">Associated Email</th>
                        <th class="py-3 text-secondary uppercase font-monospace fw-bold fs-7">Registered Course</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-people fs-1 d-block mb-3 text-secondary opacity-50"></i>
                                No registered students found in the database.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-muted">#@item.StudentId</td>
                                <td class="fw-bold text-dark">@item.FullName</td>
                                <td>@item.City</td>
                                <td class="text-muted">@(item.User?.Email ?? "N/A")</td>
                                <td>
                                    @if (item.Course != null)
                                    {
                                        <span class="badge bg-success-soft text-success px-3 py-2 rounded-pill fw-semibold">
                                            @item.Course.CourseName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-soft text-warning px-3 py-2 rounded-pill fw-semibold">
                                            Not Registered
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }
    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.1);
    }
    .fs-7 {
        font-size: 0.8rem;
    }
</style>
