@model StudentRegistrationWebApp.Models.Course
@{
    ViewData["Title"] = "Delete Course";
}

<div class="container my-5" style="max-width: 600px;">
    <div class="card border-0 shadow-lg rounded-4 p-4 border-top border-danger border-5">
        <h1 class="display-6 fw-bold text-danger mb-3">Delete Course?</h1>
        <p class="text-muted border-bottom pb-3 mb-4">Are you sure you want to permanently delete this course?</p>

        <div class="bg-light p-4 rounded-4 mb-4 shadow-inner">
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-secondary">Course ID:</div>
                <div class="col-sm-8 text-dark">#@Model.CourseId</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-secondary">Course Name:</div>
                <div class="col-sm-8 text-dark fs-5 fw-semibold">@Model.CourseName</div>
            </div>
            <div class="row">
                <div class="col-sm-4 fw-bold text-secondary">Duration:</div>
                <div class="col-sm-8 text-dark">@Model.CourseDuration Months</div>
            </div>
        </div>

        <div class="alert alert-warning border-0 small rounded-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>Deleting this course will set the course selection to null for all registered students.
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="CourseId" />
            <div class="d-flex gap-3 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-danger btn-lg px-4 rounded-pill shadow-sm">Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Cancel</a>
            </div>
        </form>
    </div>
</div>
